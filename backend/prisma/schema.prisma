// ERB Construction Finishing & Real Estate ERP System
// Comprehensive Database Schema using Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  ADMIN
  EMPLOYEE
  CONTRACTOR
  MANAGER
  ACCOUNTANT
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  LEAD
  NEGOTIATION
  CLOSED
  LOST
}

enum ProjectStatus {
  PENDING
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectStageStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  PARTIALLY_PAID
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  CHEQUE
  ONLINE
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionCategory {
  PROJECT_PAYMENT
  SALARY
  MATERIAL_PURCHASE
  EQUIPMENT_RENTAL
  MAINTENANCE
  UTILITIES
  RENTAL_INCOME
  SALE_INCOME
  OTHER
}

enum UnitType {
  APARTMENT
  VILLA
  COMMERCIAL
  OFFICE
  WAREHOUSE
  LAND
  PENTHOUSE
  STUDIO
}

enum UnitStatus {
  AVAILABLE
  RESERVED
  SOLD
  RENTED
  UNDER_MAINTENANCE
}

enum UnitFurnishingStatus {
  UNFURNISHED
  SEMI_FURNISHED
  FULLY_FURNISHED
}

enum ContractType {
  FINISHING
  SALES
  RENTAL
  MAINTENANCE
  CONSULTATION
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
  COMPLETED
}

enum InventoryTransactionType {
  IN
  OUT
  RETURN
  ADJUSTMENT
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
  PAYMENT_DUE
  PROJECT_UPDATE
  CONTRACT_EXPIRY
}

enum Language {
  ARABIC
  ENGLISH
}

// ============================================
// MODELS
// ============================================

// ---- Users & Authentication ----

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String
  firstName         String
  lastName          String
  phone             String?
  avatar            String?
  role              Role      @default(EMPLOYEE)
  language          Language  @default(ARABIC)
  darkMode          Boolean   @default(false)
  isActive          Boolean   @default(true)
  lastLogin         DateTime?
  emailVerified     Boolean   @default(false)
  emailVerifiedAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  refreshTokens     RefreshToken[]
  notifications     Notification[]
  assignedTasks     Task[]    @relation("AssignedTasks")
  createdTasks      Task[]    @relation("CreatedTasks")
  projects          Project[] @relation("ProjectManager")
  contracts         Contract[]
  payments          Payment[]
  transactions      Transaction[]

  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// ---- CRM: Client Management ----

model Client {
  id              String         @id @default(uuid())
  firstName       String
  lastName        String
  email           String         @unique
  phone           String
  altPhone        String?
  company         String?
  position        String?
  status          ClientStatus   @default(LEAD)
  source          String?        // Website, Referral, Social Media, etc.
  notes           String?
  address         String?
  city            String?
  country         String         @default("Saudi Arabia")
  nationalId      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relations
  projects        Project[]
  contracts       Contract[]
  clientNotes     ClientNote[]
  attachments     ClientAttachment[]
  interactions    ClientInteraction[]

  @@index([status])
  @@index([email])
  @@index([phone])
}

model ClientNote {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  content   String
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model ClientAttachment {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())

  @@index([clientId])
}

model ClientInteraction {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type        String   // Call, Meeting, Email, Visit
  subject     String
  description String?
  date        DateTime @default(now())
  createdBy   String?
  createdAt   DateTime @default(now())

  @@index([clientId])
}

// ---- Projects Management ----

model Project {
  id                String            @id @default(uuid())
  name              String
  description       String?
  clientId          String
  client            Client            @relation(fields: [clientId], references: [id])
  managerId         String?
  manager           User?             @relation("ProjectManager", fields: [managerId], references: [id])
  status            ProjectStatus     @default(PENDING)
  budget            Decimal           @db.Decimal(15, 2)
  actualCost        Decimal           @default(0) @db.Decimal(15, 2)
  startDate         DateTime?
  endDate           DateTime?
  actualEndDate     DateTime?
  progress          Int               @default(0) // Percentage
  location          String?
  area              Decimal?          @db.Decimal(10, 2) // Square meters
  contractValue     Decimal?          @db.Decimal(15, 2)
  profitMargin      Decimal?          @db.Decimal(5, 2)
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  stages            ProjectStage[]
  tasks             Task[]
  materials         ProjectMaterial[]
  payments          Payment[]
  contractorAssignments ContractorAssignment[]
  photos            ProjectPhoto[]

  @@index([clientId])
  @@index([status])
  @@index([managerId])
}

model ProjectStage {
  id          String              @id @default(uuid())
  projectId   String
  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?
  order       Int
  status      ProjectStageStatus  @default(NOT_STARTED)
  budget      Decimal             @db.Decimal(15, 2)
  actualCost  Decimal             @default(0) @db.Decimal(15, 2)
  startDate   DateTime?
  endDate     DateTime?
  progress    Int                 @default(0) // Percentage
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // Relations
  tasks         Task[]
  materials     ProjectMaterial[]

  @@index([projectId])
  @@index([status])
}

model ProjectPhoto {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  createdAt DateTime @default(now())

  @@index([projectId])
}

// ---- Tasks ----

model Task {
  id          String      @id @default(uuid())
  title       String
  description String?
  projectId   String
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId     String?
  stage       ProjectStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  assigneeId  String?
  assignee    User?       @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  creatorId   String?
  creator     User?       @relation("CreatedTasks", fields: [creatorId], references: [id], onDelete: SetNull)
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([priority])
}

// ---- Contractors Management ----

model Contractor {
  id              String   @id @default(uuid())
  name            String
  email           String   @unique
  phone           String
  altPhone        String?
  specialty       String[] // Plumbing, Electrical, Painting, etc.
  experienceYears Int?
  idNumber        String?  // National ID / Iqama
  rating          Decimal  @default(0) @db.Decimal(3, 2)
  dailyRate       Decimal? @db.Decimal(10, 2)
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  assignments     ContractorAssignment[]
  reviews         ContractorReview[]

  @@index([email])
  @@index([specialty])
}

model ContractorAssignment {
  id           String   @id @default(uuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role         String?   // Lead, Supervisor, Worker
  hourlyRate   Decimal?  @db.Decimal(10, 2)
  startDate    DateTime @default(now())
  endDate      DateTime?
  status       String   @default("ACTIVE")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([contractorId])
  @@index([projectId])
}

model ContractorReview {
  id           String   @id @default(uuid())
  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)
  projectId    String?
  rating       Decimal  @db.Decimal(3, 2) // 1-5
  comment      String?
  createdBy    String?
  createdAt    DateTime @default(now())

  @@index([contractorId])
}

// ---- Real Estate Management ----

model Unit {
  id              String               @id @default(uuid())
  title           String
  description     String?
  type            UnitType
  status          UnitStatus           @default(AVAILABLE)
  furnishingStatus UnitFurnishingStatus @default(UNFURNISHED)
  price           Decimal              @db.Decimal(15, 2)
  rentPrice       Decimal?             @db.Decimal(10, 2) // Monthly rent
  area            Decimal              @db.Decimal(10, 2) // Square meters
  bedrooms        Int?
  bathrooms       Int?
  floor           Int?
  buildingName    String?
  location        String?
  city            String
  country         String               @default("Saudi Arabia")
  amenities       String[]             // Pool, Gym, Parking, Security, etc.
  yearBuilt       Int?
  images          String[]
  notes           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  // Relations
  contracts       Contract[]
  unitFeatures    UnitFeature[]

  @@index([type])
  @@index([status])
  @@index([city])
  @@index([price])
}

model UnitFeature {
  id     String @id @default(uuid())
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  name   String
  value  String?

  @@index([unitId])
}

// ---- Contracts ----

model Contract {
  id             String         @id @default(uuid())
  contractNumber String         @unique // Auto-generated
  type           ContractType
  status         ContractStatus @default(DRAFT)
  title          String
  description    String?
  
  // Client relation
  clientId       String
  client         Client         @relation(fields: [clientId], references: [id])
  
  // Project relation (optional)
  projectId      String?
  project        Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  // Unit relation (optional)
  unitId         String?
  unit           Unit?          @relation(fields: [unitId], references: [id], onDelete: SetNull)
  
  // Financials
  contractValue  Decimal        @db.Decimal(15, 2)
  paidAmount     Decimal        @default(0) @db.Decimal(15, 2)
  remainingAmount Decimal       @db.Decimal(15, 2)
  
  // Dates
  startDate      DateTime
  endDate        DateTime
  renewalDate    DateTime?
  
  // Terms
  terms          String?
  conditions     String?
  notes          String?
  
  // File
  documentUrl    String?
  
  // Created by
  createdById    String?
  createdBy      User?          @relation(fields: [createdById], references: [id])
  
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  // Relations
  payments       Payment[]

  @@index([contractNumber])
  @@index([type])
  @@index([status])
  @@index([clientId])
  @@index([projectId])
  @@index([unitId])
}

// ---- Payments ----

model Payment {
  id             String        @id @default(uuid())
  paymentNumber  String        @unique // Auto-generated
  contractId     String
  contract       Contract      @relation(fields: [contractId], references: [id])
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  amount         Decimal       @db.Decimal(15, 2)
  paidAmount     Decimal       @default(0) @db.Decimal(15, 2)
  status         PaymentStatus @default(PENDING)
  paymentMethod  PaymentMethod @default(CASH)
  dueDate        DateTime
  paymentDate    DateTime?
  notes          String?
  receiptUrl     String?
  createdById    String?
  createdBy      User?         @relation(fields: [createdById], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([contractId])
  @@index([projectId])
  @@index([status])
  @@index([dueDate])
}

// ---- Accounting ----

model Transaction {
  id          String               @id @default(uuid())
  type        TransactionType
  category    TransactionCategory
  amount      Decimal              @db.Decimal(15, 2)
  description String
  referenceId String?              // Related entity ID
  referenceType String?            // Related entity type
  date        DateTime             @default(now())
  createdById String?
  createdBy   User?                @relation(fields: [createdById], references: [id])
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([type])
  @@index([category])
  @@index([date])
}

// ---- Inventory Management ----

model InventoryItem {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique // SKU
  category    String   // Ceramic, Paint, Electrical, Plumbing, etc.
  description String?
  unit        String   @default("piece") // piece, meter, kg, liter, box
  quantity    Decimal  @default(0) @db.Decimal(10, 2)
  minQuantity Decimal  @default(0) @db.Decimal(10, 2) // Minimum stock level
  price       Decimal  @db.Decimal(10, 2) // Unit price
  supplier    String?
  location    String?  // Warehouse location
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  transactions InventoryTransaction[]
  projectMaterials ProjectMaterial[]

  @@index([code])
  @@index([category])
}

model InventoryTransaction {
  id              String                   @id @default(uuid())
  itemId          String
  item            InventoryItem            @relation(fields: [itemId], references: [id])
  type            InventoryTransactionType
  quantity        Decimal                  @db.Decimal(10, 2)
  unitPrice       Decimal                  @db.Decimal(10, 2)
  totalAmount     Decimal                  @db.Decimal(15, 2)
  referenceId     String?                  // Related project/order ID
  referenceType   String?                  // Related entity type
  notes           String?
  performedById   String?
  createdAt       DateTime                 @default(now())

  @@index([itemId])
  @@index([type])
  @@index([createdAt])
}

model ProjectMaterial {
  id          String   @id @default(uuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stageId     String?
  stage       ProjectStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id])
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(10, 2)
  totalCost   Decimal  @db.Decimal(15, 2)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([itemId])
}

// ---- Notifications ----

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(INFO)
  title     String
  message   String
  isRead    Boolean          @default(false)
  link      String?          // Link to related entity
  data      Json?            // Additional notification data
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ---- Audit Log ----

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String   // CREATE, UPDATE, DELETE, LOGIN, etc.
  entity    String   // Entity type affected
  entityId  String?  // Entity ID affected
  changes   Json?    // Before/After changes
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}
